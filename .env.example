# --- Database (used by both docker-compose.yml and Spring Boot's application.yml) ---

# Name of the Postgres database Docker Compose will create on first run
DB_NAME=casi

# Postgres user Docker Compose will create with access to DB_NAME
DB_USER=casi_user

# Postgres password for DB_USER - change this to something real for any non-local environment
DB_PASSWORD=casi_dev_password

# Full JDBC connection string Spring Boot uses to reach Postgres.
# "localhost" works because docker-compose.yml maps container port 5432 to your machine's 5432.
DB_URL=jdbc:postgresql://localhost:5432/casi

# --- JWT (not used until Step 3 - Auth Module - but declared now per Part 12's secrets-management rule) ---

# Secret Spring Security uses to sign/verify JWTs (HS256). Generate a real random 256-bit+ value
# for anything beyond local dev - e.g.: openssl rand -base64 32
JWT_SECRET=replace-this-with-a-long-random-string-before-real-use

# --- CORS (not used until Step 3 - SecurityConfig) ---

# Origin of your frontend dev server, so SecurityConfig can allow it explicitly (never use "*")
FRONTEND_ORIGIN=http://localhost:5173
